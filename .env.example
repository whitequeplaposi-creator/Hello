# ============================================================
# Vercel Environment Variables — kopiera dessa till Vercel Dashboard
# Settings → Environment Variables
# ============================================================

# Stripe (hämta från https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Webhook Secret (hämta från https://dashboard.stripe.com/webhooks)
# Klicka på din webhook-endpoint → "Signing secret" → Reveal
STRIPE_WEBHOOK_SECRET=whsec_...

# Turso Database (hämta från https://turso.tech/app)
DATABASE_URL=libsql://your-db.turso.io
DATABASE_AUTH_TOKEN=your-auth-token

# Firebase (hämta från https://console.firebase.google.com)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
